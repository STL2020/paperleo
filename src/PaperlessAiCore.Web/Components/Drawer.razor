@if (Open)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-slate-900/30 dark:bg-black/50 backdrop-blur-sm z-40 animate-fade-in" @onclick="Close"></div>

    <!-- Panel -->
    <div class="fixed top-0 right-0 h-full w-full sm:w-[440px] z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-2xl border-l border-white/40 dark:border-white/10 shadow-2xl flex flex-col animate-drawer-in">
        <div class="flex items-center justify-between px-6 py-5 border-b border-slate-900/5 dark:border-white/5 shrink-0">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 m-0">@Title</h2>
            <button @onclick="Close" class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:bg-slate-900/5 dark:hover:bg-white/10 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
                ✕
            </button>
        </div>
        <div class="flex-1 overflow-y-auto px-6 py-5">
            @ChildContent
        </div>
        @if (FooterContent is not null)
        {
            <div class="px-6 py-4 border-t border-slate-900/5 dark:border-white/5 shrink-0">
                @FooterContent
            </div>
        }
    </div>
}

<style>
    @@keyframes drawerIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
    .animate-drawer-in { animation: drawerIn 0.25s cubic-bezier(0.16, 1, 0.3, 1); }
</style>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    private async Task Close()
    {
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }
}
