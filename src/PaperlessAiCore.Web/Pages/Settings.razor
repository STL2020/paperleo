@code {
    private bool _loading = true;
    private string? _loadError;
    private bool _proMode;
    private SettingsDto _settings = new();

    private bool _saving;
    private string? _savedMessage;
    private bool _loadingFields, _creatingField;

    private bool _testingPaperless, _testingLlm;
    private ConnectionTestResult? _paperlessTestResult, _llmTestResult;

    private bool _suggestingTags, _suggestingDocTypes, _seedingTags, _seedingDocTypes;
    private bool _importingTagsFromPaperless, _importingDocTypesFromPaperless;
    private SuggestVocabularyResult? _suggestTagsResult, _suggestDocTypesResult;
    private SeedTagsResult? _seedTagsResult, _seedDocTypesResult;

    // Lizenz
    private string _licenseKey = "";
    private string? _licenseMessage;
    private bool _licenseSuccess;
    private bool _activatingLicense;

    private bool _exportingSettings;
    private bool _importExportSuccess;
    private string? _importExportMessage;

    private async Task ExportSettings()
    {
        _exportingSettings = true; StateHasChanged();
        try
        {
            var content = await Api.ExportSettingsAsync();
            if (!string.IsNullOrEmpty(content))
            {
                var fileName = $"paperleo-settings-{DateTime.Now:yyyy-MM-dd}.env";
                await JS.InvokeVoidAsync("downloadTextFile", fileName, content);
                _importExportSuccess = true;
                _importExportMessage = "Export erfolgreich ✓";
            }
            else { _importExportSuccess = false; _importExportMessage = "Export fehlgeschlagen."; }
        }
        catch (Exception ex) { _importExportSuccess = false; _importExportMessage = ex.Message; }
        _exportingSettings = false;
        await Task.Delay(3000); _importExportMessage = null; StateHasChanged();
    }

    private async Task ImportSettings(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 1024 * 1024);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var (success, msg) = await Api.ImportSettingsAsync(content);
            _importExportSuccess = success;
            _importExportMessage = msg;
            if (success)
            {
                await Task.Delay(1500);
                Nav.NavigateTo("/settings", forceLoad: true);
            }
        }
        catch (Exception ex) { _importExportSuccess = false; _importExportMessage = ex.Message; }
        StateHasChanged();
    }

    private async Task ActivateLicense()
    {
        if (string.IsNullOrWhiteSpace(_licenseKey)) return;
        _activatingLicense = true; _licenseMessage = null; StateHasChanged();
        try
        {
            var result = await Api.ActivateLicenseAsync(_licenseKey.Trim());
            if (result.Success)
            {
                _licenseSuccess = true;
                _licenseMessage = "Lizenz aktiviert — paperLeo Pro ist jetzt freigeschaltet!";
                _settings.PremiumLicenseKey = _licenseKey.Trim();
                await Save();
            }
            else
            {
                _licenseSuccess = false;
                _licenseMessage = result.Message ?? "Ungültiger Lizenzschlüssel.";
            }
        }
        catch { _licenseSuccess = false; _licenseMessage = "Verbindungsfehler bei der Lizenzprüfung."; }
        _activatingLicense = false; StateHasChanged();
    }

    private async Task DeactivateLicense()
    {
        _settings.PremiumLicenseKey = "";
        _licenseKey = "";
        _licenseMessage = "Lizenz deaktiviert.";
        _licenseSuccess = false;
        await Save();
    }

    private bool _promptContainsPersonalData;
