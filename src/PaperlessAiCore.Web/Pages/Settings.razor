@using PaperlessAiCore.Web.Services
@page "/settings"
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="settings-page">

    @if (_loading)
    {
        <div style="display:flex;align-items:center;gap:10px;padding:40px 24px;color:var(--muted);">
            <div class="loading-spinner"></div> Einstellungen werden geladen …
        </div>
    }
    else if (_loadError is not null)
    {
        <div style="padding:24px;">
            <div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:16px;">
                <p style="font-size:13px;font-weight:500;color:#ef4444;margin:0 0 4px;">Fehler beim Laden</p>
                <p style="font-size:12px;color:var(--muted);margin:0 0 12px;">@_loadError</p>
                <button class="btn secondary" @onclick="Retry">Erneut versuchen</button>
            </div>
        </div>
    }
    else
    {
        <div class="settings-content">

                @if (SettingsTabState.ActiveTab == "Verbindung & KI")
                {
                    <div class="sgroup">
                        <p class="stitle">Paperless-ngx</p>
                        <div class="sbox">
                            <div class="sfield"><label>@Loc["conn.url"]</label><input @bind="_settings.PaperlessUrl" @bind:event="oninput" @bind:after="AutoSaveAsync" placeholder="http://192.168.1.10:8000" /></div>
                            <div class="sfield"><label>@Loc["conn.token"]</label><input @bind="_settings.PaperlessApiToken" @bind:event="oninput" @bind:after="AutoSaveAsync" type="password" placeholder="Mein Profil → API-Token" /></div>
                            <div class="sfield"><label>@Loc["conn.tag"]</label><input @bind="_settings.ProcessedTagName" @bind:event="oninput" @bind:after="AutoSaveAsync" placeholder="KI-Check" /></div>
                            <div class="saction">
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="TestPaperless" disabled="@_testingPaperless">@(_testingPaperless ? "Teste …" : Loc["conn.test"])</button>
                                @if (_paperlessTestResult is not null)
                                {
                                    <span class="badge @(_paperlessTestResult.Success ? "ok" : "error")">@_paperlessTestResult.Message @if (_paperlessTestResult.DocumentCount is not null) { <text>(@_paperlessTestResult.DocumentCount Dok.)</text> }</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"KI-Provider":"AI Provider")</p>
                        <div class="sbox">
                            <div class="sfield">
                                <label>Schnellauswahl</label>
                                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                    @foreach (var p in _providers)
                                    {
                                        <button type="button" class="preset-btn @(p.Key == _activeProvider ? "active" : "")"
                                                @onclick="() => ApplyPreset(p.Key)"
                                                title="@p.ApiBase">
                                            @((MarkupString)p.Icon) @p.Label
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="two-col">
                                <div class="sfield"><label>@Loc["conn.model"]</label><input @bind="_settings.LlmModel" @bind:event="oninput" @bind:after="AutoSaveAsync" placeholder="gemini-2.5-flash" /></div>
                                <div class="sfield"><label>@Loc["conn.apikey"]</label><input @bind="_settings.LlmApiKey" @bind:event="oninput" @bind:after="AutoSaveAsync" type="password" placeholder="sk-…" /></div>
                                <div class="sfield"><label>@Loc["conn.apibase"]</label><input @bind="_settings.LlmApiBase" @bind:event="oninput" @bind:after="AutoSaveAsync" placeholder="leer = api.openai.com" /></div>
                                <div class="sfield"><label>@Loc["conn.maxtoken"]</label><input type="number" min="256" step="256" @bind="_settings.LlmMaxTokens" /></div>
                            </div>
                            <div class="saction">
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="TestLlm" disabled="@_testingLlm">@(_testingLlm ? "Teste …" : Loc["conn.test_ki"])</button>
                                @if (_llmTestResult is not null)
                                {
                                    <span class="badge @(_llmTestResult.Success ? "ok" : "error")">@_llmTestResult.Message</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="sgroup">
                        <p class="stitle">Webhook (optional)</p>
                        <div class="sbox">
                            <p class="shint mb-2">@(AppLoc.Current=="de"?"Paperless: Workflows → Trigger 'Dokument hinzugefügt' → Webhook, Parameter url = {doc_url}":"Paperless: Workflows → Trigger 'Document added' → Webhook, parameter url = {doc_url}")</p>
                            <input readonly value="@WebhookUrl" onclick="this.select()" style="width:100%;font-family:monospace;font-size:12px;" />
                        </div>
                    </div>

                    <!-- KI-KOSTENKONTROLLE (Pro) -->
                    <div class="sgroup">
                        <p class="stitle">
                            @Loc["conn.cost_title"]
                            @if (!_proMode) { <span class="badge" style="background:rgba(245,158,11,.1);color:#fbbf24;border:1px solid rgba(245,158,11,.2);font-size:10px;margin-left:6px;">Pro</span> }
                        </p>
                        <div class="sbox">
                            @if (!_proMode)
                            {
                                <div class="demo-hint">@(AppLoc.Current=="de"?"KI-Kostenkontrolle ist ein Pro-Feature.":"AI Cost Control is a Pro feature.")</div>
                            }
                            <div class="two-col">
                                <div class="sfield">
                                    <label>@Loc["conn.pages_limit"]</label>
                                    <input type="number" min="0" step="1" @bind="_settings.MaxPagesPerDocument" disabled="@(!_proMode)" />
                                    <p class="shint">@(AppLoc.Current=="de"?"Nur die ersten N Seiten werden an die KI gesendet. 0 = alle Seiten. Spart Tokens bei langen PDFs.":"Only the first N pages are sent to the AI. 0 = all pages. Saves tokens on long PDFs.")</p>
                                </div>
                                <div class="sfield">
                                    <label>@Loc["conn.token_limit"]</label>
                                    <input type="number" min="0" step="10000" @bind="_settings.MonthlyTokenLimit" disabled="@(!_proMode)" />
                                    <p class="shint">@(AppLoc.Current=="de"?"Ab diesem Limit werden keine Dokumente mehr verarbeitet. 0 = kein Limit.":"Once this limit is reached, no more documents will be processed. 0 = no limit.")</p>
                                </div>
                                <div class="sfield">
                                    <label>@Loc["conn.cost_limit"]</label>
                                    <input type="number" min="0" step="0.50" @bind="_settings.MonthlyCostLimitEur" disabled="@(!_proMode)" />
                                    <p class="shint">@(AppLoc.Current=="de"?"Geschätztes Kostenlimit pro Monat in €. paperLeo stoppt wenn das Limit erreicht ist. 0 = kein Limit.":"Estimated monthly cost limit in €. paperLeo stops processing when the limit is reached. 0 = no limit.")</p>
                                </div>
                                <div class="sfield">
                                    <label>@Loc["conn.token_used"]</label>
                                    <input type="number" readonly value="@_settings.MonthlyTokenUsed" style="opacity:.6;" />
                                    <p class="shint">@(AppLoc.Current=="de"?"Wird automatisch gezählt.":"Counted automatically.") <button class="btn secondary !py-0.5 !text-xs !px-2" style="margin-left:4px;" @onclick="ResetMonthlyTokens" disabled="@(!_proMode)">Zurücksetzen</button></p>
                                </div>
                            </div>
                            @if (_proMode && _settings.MonthlyTokenLimit > 0)
                            {
                                var pct = Math.Min(100, (int)(_settings.MonthlyTokenUsed * 100.0 / _settings.MonthlyTokenLimit));
                                var color = pct > 80 ? "#ef4444" : pct > 60 ? "#f59e0b" : "var(--c-accent)";
                                <div style="margin-top:8px;">
                                    <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--c-muted);margin-bottom:4px;">
                                        <span>Token-Verbrauch</span>
                                        <span style="color:@color;">@_settings.MonthlyTokenUsed.ToString("N0") / @_settings.MonthlyTokenLimit.ToString("N0") (@pct%)</span>
                                    </div>
                                    <div style="height:6px;background:var(--c-border);border-radius:999px;overflow:hidden;">
                                        <div style="height:100%;width:@pct%;background:@color;border-radius:999px;transition:width .3s;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (SettingsTabState.ActiveTab == "Verhalten")
                {
                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Auto-Modus":"Auto Mode")</p>
                        <div class="sbox">
                            <div class="toggle-row"><div><div class="text-sm font-medium">@(AppLoc.Current=="de"?"Auto-Modus aktivieren":"Enable auto mode")</div><div class="shint">@(AppLoc.Current=="de"?"Scannt automatisch neue Dokumente.":"Automatically scans new documents.")</div></div><input type="checkbox" @bind="_settings.AutoModeEnabled" /></div>
                            <div class="sfield mt-3"><label>@Loc["beh.interval"]</label><input type="number" min="30" step="30" @bind="_settings.PollIntervalSeconds" style="width:120px;" /></div>
                        </div>
                    </div>

                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"KI-Funktionen":"AI Features")</p>
                        <div class="sbox">
                            <div class="toggle-row"><span class="text-sm">@(AppLoc.Current=="de"?"Tags vergeben":"Assign tags")</span><input type="checkbox" @bind="_settings.EnableTagsAssignment" /></div>
                            <div class="toggle-row"><span class="text-sm">@(AppLoc.Current=="de"?"Korrespondent erkennen":"Detect correspondents")</span><input type="checkbox" @bind="_settings.EnableCorrespondentDetection" /></div>
                            <div class="toggle-row"><span class="text-sm">@Loc["beh.doctype"]</span><input type="checkbox" @bind="_settings.EnableDocumentTypeClassification" /></div>
                            <div class="toggle-row"><span class="text-sm">@Loc["beh.title_gen"]</span><input type="checkbox" @bind="_settings.EnableTitleGeneration" /></div>
                            <div class="toggle-row @(!_proMode ? "opacity-50" : "")">
                                <span class="text-sm">@Loc["beh.custom_fields"] @(!_proMode ? "· Pro" : "")</span>
                                <input type="checkbox" @bind="_settings.EnableCustomFields" disabled="@(!_proMode)" />
                            </div>
                        </div>
                    </div>

                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Einschränkungen":"Restrictions")</p>
                        <div class="sbox">
                            <div class="toggle-row"><span class="text-sm">@Loc["beh.only_corr"]</span><input type="checkbox" @bind="_settings.UseExistingCorrespondentsOnly" /></div>
                            <div class="toggle-row"><span class="text-sm">@Loc["beh.only_types"]</span><input type="checkbox" @bind="_settings.UseExistingDocumentTypesOnly" /></div>
                            <div class="toggle-row"><span class="text-sm">@Loc["beh.only_tags"]</span><input type="checkbox" @bind="_settings.UseExistingTagsOnly" /></div>
                        </div>
                    </div>

                    <!-- TITEL-GENERATOR -->
                    <div class="sgroup">
                        <p class="stitle">
                            @Loc["beh.title_format"]
                            @if (!_proMode) { <span class="badge" style="background:rgba(245,158,11,.1);color:#fbbf24;border:1px solid rgba(245,158,11,.2);font-size:10px;margin-left:6px;">Pro</span> }
                        </p>
                        <div class="sbox">
                            @if (!_proMode)
                            {
                                <div class="demo-hint">@(AppLoc.Current=="de"?"Titel-Format-Anpassung ist ein Pro-Feature.":"Title Format customization is a Pro feature.")</div>
                            }
                            <p style="font-size:12px;color:var(--c-muted);margin:0 0 12px;line-height:1.6;">@(AppLoc.Current=="de"?"Definiere wie Dokumenttitel aufgebaut werden. Klicke Bausteine an um sie hinzuzufügen, verschiebe sie mit den Pfeilen.":"Define how document titles are structured. Click blocks to add them, use arrows to reorder.")</p>

                            <!-- Vorschau -->
                            <div style="padding:8px 12px;background:rgba(29,158,117,.06);border:1px solid rgba(29,158,117,.2);border-radius:8px;margin-bottom:12px;">
                                <p style="font-size:10px;color:var(--c-muted);margin:0 0 3px;text-transform:uppercase;letter-spacing:.06em;">@(AppLoc.Current=="de"?(AppLoc.Current=="de"?"Vorschau":"Preview"):"Preview")</p>
                                <p style="font-size:13px;font-weight:600;color:var(--c-text);margin:0;">@string.Join(_titelTrennzeichen, _titelBausteine.Select(b => $"[{b}]"))</p>
                                <p style="font-size:11px;color:var(--c-muted);margin:3px 0 0;">@string.Join(_titelTrennzeichen, _titelBausteine.Select(TitelBeispiel))</p>
                            </div>

                            <!-- Aktive Bausteine -->
                            <p style="font-size:11px;font-weight:600;color:var(--c-text);margin:0 0 6px;">@(AppLoc.Current=="de"?"Aktive Bausteine":"Active blocks")</p>
                            <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:10px;">
                                @for (int bi = 0; bi < _titelBausteine.Count; bi++)
                                {
                                    var bIdx = bi;
                                    var bName = _titelBausteine[bi];
                                    <div style="display:flex;align-items:center;gap:6px;background:var(--c-accent-t);border:1px solid rgba(29,158,117,.25);border-radius:7px;padding:6px 10px;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="var(--c-accent)" stroke-width="2" style="width:12px;height:12px;flex-shrink:0;"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                                        <span style="font-size:12px;font-weight:600;color:var(--c-accent);flex:1;">@bName</span>
                                        <button @onclick='() => { if(bIdx>0){var t=_titelBausteine[bIdx-1];_titelBausteine[bIdx-1]=_titelBausteine[bIdx];_titelBausteine[bIdx]=t;} }' disabled="@(bIdx==0||!_proMode)" style="background:none;border:none;cursor:pointer;color:var(--c-muted);padding:1px 3px;font-size:13px;">▲</button>
                                        <button @onclick='() => { if(bIdx<_titelBausteine.Count-1){var t=_titelBausteine[bIdx+1];_titelBausteine[bIdx+1]=_titelBausteine[bIdx];_titelBausteine[bIdx]=t;} }' disabled="@(bIdx==_titelBausteine.Count-1||!_proMode)" style="background:none;border:none;cursor:pointer;color:var(--c-muted);padding:1px 3px;font-size:13px;">▼</button>
                                        <button @onclick='() => _titelBausteine.Remove(bName)' disabled="@(!_proMode)" style="background:none;border:none;cursor:pointer;color:var(--c-muted);font-size:15px;padding:0 3px;">×</button>
                                    </div>
                                }
                            </div>

                            <!-- Verfügbare Bausteine -->
                            <p style="font-size:11px;font-weight:600;color:var(--c-text);margin:0 0 6px;">@(AppLoc.Current=="de"?"Hinzufügen":"Add")</p>
                            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px;">
                                @foreach (var b in AlleTitelBausteine.Where(b => !_titelBausteine.Contains(b)))
                                {
                                    var bCopy = b;
                                    <button @onclick='() => { if(_proMode) _titelBausteine.Add(bCopy); }' disabled="@(!_proMode)"
                                            style="padding:4px 10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:6px;font-size:11px;color:var(--c-muted);cursor:pointer;">
                                        + @b
                                    </button>
                                }
                            </div>

                            <!-- Trennzeichen -->
                            <p style="font-size:11px;font-weight:600;color:var(--c-text);margin:0 0 6px;">@(AppLoc.Current=="de"?"Trennzeichen":"Separator")</p>
                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                @foreach (var tz in new[]{ " – ", " · ", " - ", " | ", " / " })
                                {
                                    var tzCopy = tz;
                                    <button @onclick='() => { if(_proMode) _titelTrennzeichen = tzCopy; }' disabled="@(!_proMode)"
                                            style="padding:4px 10px;background:@(_titelTrennzeichen==tz?"rgba(29,158,117,.15)":"rgba(255,255,255,.04)");border:1px solid @(_titelTrennzeichen==tz?"rgba(29,158,117,.4)":"rgba(255,255,255,.1)");border-radius:6px;font-size:11px;color:@(_titelTrennzeichen==tz?"var(--c-accent)":"var(--c-muted)");cursor:pointer;">
                                        A@(tz)B
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (SettingsTabState.ActiveTab == "Vokabular")
                {
                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Tag-Vokabular":"Tag Vocabulary")</p>
                        <div class="sbox">
                            @if (!_proMode) { <div class="demo-hint">🔒 Community: Vokabular auf 5 Standard-Tags beschränkt. <strong>Pro</strong> = eigenes Vokabular, Import aus Paperless, KI-Vorschläge.</div> }
                            <div class="sfield"><label>@Loc["voc.comma_sep"]</label><textarea @bind="_settings.DefaultTagVocabulary" rows="3" disabled="@(!_proMode)" placeholder="z.B. Strom, Wasser, Mietobjekt A, Max …"></textarea></div>
                            <div class="saction">
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="SuggestTags" disabled="@(_suggestingTags || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "KI analysiert deine letzten Dokumente und schlägt passende Tags vor")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                                    @(_suggestingTags ? Loc["voc.analyzing"] : Loc["voc.ai_suggest"])
                                </button>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="ImportTagsFromPaperless" disabled="@(_importingTagsFromPaperless || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "Bestehende Tags aus Paperless ins Vokabular importieren")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
                                    @(_importingTagsFromPaperless ? Loc["voc.importing"] : Loc["voc.import_pl"])
                                </button>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="SeedTags" disabled="@(_seedingTags || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "Vokabular als neue Tags in Paperless anlegen")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                                    @(_seedingTags ? Loc["voc.seeding"] : Loc["voc.seed"])
                                </button>
                            </div>
                            @if (_seedTagsResult is not null) { <div class="mt-2"><span class="badge ok">@(_seedTagsResult.CreatedCount) angelegt, @(_seedTagsResult.AlreadyExistedCount) vorhanden</span></div> }
                        </div>
                    </div>

                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Dokumenttyp-Vokabular":"Document Type Vocabulary")</p>
                        <div class="sbox">
                            @if (!_proMode) { <div class="demo-hint">🔒 Community: Vokabular auf 5 Standard-Typen beschränkt. <strong>Pro</strong> = eigenes Vokabular, Import aus Paperless, KI-Vorschläge.</div> }
                            <div class="sfield"><label>@Loc["voc.comma_sep"]</label><textarea @bind="_settings.DefaultDocumentTypeVocabulary" rows="3" disabled="@(!_proMode)" placeholder="z.B. Rechnung, Vertrag, Mahnung …"></textarea></div>
                            <div class="saction">
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="SuggestDocumentTypes" disabled="@(_suggestingDocTypes || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "KI analysiert deine letzten Dokumente und schlägt passende Typen vor")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                                    @(_suggestingDocTypes ? Loc["voc.analyzing"] : Loc["voc.ai_suggest"])
                                </button>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="ImportDocTypesFromPaperless" disabled="@(_importingDocTypesFromPaperless || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "Bestehende Dokumenttypen aus Paperless ins Vokabular importieren")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
                                    @(_importingDocTypesFromPaperless ? Loc["voc.importing"] : Loc["voc.import_pl"])
                                </button>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="SeedDocumentTypes" disabled="@(_seedingDocTypes || !_proMode)" title="@(!_proMode ? "Nur in Pro verfügbar" : "Vokabular als neue Dokumenttypen in Paperless anlegen")">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                                    @(_seedingDocTypes ? Loc["voc.seeding"] : Loc["voc.seed"])
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (SettingsTabState.ActiveTab == "Korrespondenten")
                {
                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Korrespondenten":"Correspondents")</p>
                        <div class="sbox">
                            <p class="shint">Korrespondenten werden automatisch aus Dokumenten erkannt und in Paperless angelegt. Duplikat-Erkennung folgt in einer kommenden Version.</p>
                        </div>
                    </div>
                }

                @if (SettingsTabState.ActiveTab == "Prompt-Assistent")
                {
                    @if (_archiveImportDone)
                    {
                        <div style="background:rgba(29,158,117,.08);border:1px solid rgba(29,158,117,.25);border-radius:10px;padding:12px 16px;margin-bottom:4px;display:flex;align-items:center;gap:10px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--c-accent)" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
                            <p style="font-size:12px;color:var(--c-text);margin:0;">
                                <strong>Archiv-Analyse importiert</strong> — Personen, Adressen, Fahrzeuge und Arbeitgeber wurden vorausgefüllt. Bitte prüfe und ergänze die Daten.
                            </p>
                            <button @onclick='() => _archiveImportDone = false' style="background:none;border:none;cursor:pointer;color:var(--c-muted);margin-left:auto;font-size:16px;padding:0;">×</button>
                        </div>
                    }
                    @if (_archiveExtraInfo.Any())
                    {
                        <div style="background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.2);border-radius:10px;padding:12px 16px;margin-bottom:4px;">
                            <p style="font-size:11px;font-weight:600;color:#a5b4fc;margin:0 0 8px;">Weitere gefundene Daten (werden in den Prompt eingebaut):</p>
                            @foreach (var kv in _archiveExtraInfo)
                            {
                                <div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04);">
                                    <span style="color:var(--c-muted);">@kv.Key</span>
                                    <span style="color:var(--c-text);font-family:monospace;">@kv.Value</span>
                                </div>
                            }
                        </div>
                    }
                    <div class="sgroup">
                        <p class="stitle">@Loc["pa.step"] @_promptStep @Loc["pa.of"] 9 — @_promptStepLabel</p>
                        <div class="sbox" style="min-height:300px;">

                            @if (_promptStep == 1)
                            {
                                <!-- SCHRITT 1: SETUP-CHECK -->
                                <div style="margin-bottom:12px;">
                                    <p style="font-size:13px;color:var(--text);margin:0 0 6px;">@(AppLoc.Current=="de"?"paperLeo benötigt 13 Standard-Felder für den vollen Funktionsumfang.":"paperLeo needs 13 standard fields for full functionality.")</p>
                                    <p style="font-size:12px;color:var(--muted);margin:0 0 12px;">@(AppLoc.Current=="de"?"Fehlende Felder werden automatisch in Paperless angelegt — bestehende Daten bleiben erhalten.":"Missing fields are automatically created in Paperless — existing data remains unchanged.")</p>
                                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                                        <div style="flex:1;height:6px;background:var(--border);border-radius:999px;overflow:hidden;">
                                            <div style="width:@(SetupPct)%;height:100%;background:var(--accent);border-radius:999px;transition:width .4s;"></div>
                                        </div>
                                        <span style="font-size:13px;font-weight:500;color:var(--accent);white-space:nowrap;">@SetupFound / 13</span>
                                    </div>
                                    @if (SetupMissing.Any())
                                    {
                                        <div style="background:rgba(29,158,117,.05);border:1px solid rgba(29,158,117,.15);border-radius:8px;padding:10px 12px;margin-bottom:10px;">
                                            <p style="font-size:12px;font-weight:500;color:var(--accent);margin:0 0 6px;">Fehlende Felder (@SetupMissing.Count):</p>
                                            <div style="display:flex;flex-wrap:wrap;gap:5px;">
                                                @foreach (var f in SetupMissing)
                                                { <span style="font-size:11px;padding:2px 8px;border-radius:999px;background:rgba(239,68,68,.08);color:#ef4444;border:1px solid rgba(239,68,68,.2);">@f</span> }
                                            </div>
                                        </div>
                                        <button class="btn !py-1.5 !text-sm" @onclick="CreateMissingFieldsAsync" disabled="@_creatingMissingFields">
                                            @if (_creatingMissingFields) { <div class="loading-spinner" style="width:13px;height:13px;border-width:2px;margin:0;"></div> }
                                            @(_creatingMissingFields ? "Lege Felder an …" : $"{SetupMissing.Count} fehlende Felder jetzt anlegen")
                                        </button>
                                    }
                                    else
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;padding:10px 12px;background:rgba(29,158,117,.05);border:1px solid rgba(29,158,117,.15);border-radius:8px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                            <span style="font-size:13px;color:var(--accent);">Alle 13 Standard-Felder vorhanden — bereit für den Assistenten.</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(_setupMessage)) { <p class="shint mt-2" style="color:var(--accent);">@_setupMessage</p> }
                                </div>
                            }
                            else if (_promptStep == 2)
                            {
                                <!-- SCHRITT 2: PERSONEN -->
                                <p class="shint mb-3">Wer taucht in Dokumenten auf? Vornamen genügen — für das Feld „Familienmitglied".</p>
                                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
                                    @foreach (var p in _assistPersons)
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 12px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                            <input value="@p.Name" @oninput='e => UpdatePersonName(_assistPersons.IndexOf(p), e.Value?.ToString() ?? string.Empty)' placeholder="Vorname" style="flex:1;font-size:13px;" />
                                            <select value="@p.Role" @onchange='e => UpdatePersonRole(_assistPersons.IndexOf(p), e.Value?.ToString() ?? "Hauptnutzer")' style="font-size:12px;width:auto;">
                                                <option>Hauptnutzer</option>
                                                <option>Partner/in</option>
                                                <option>Kind</option>
                                                <option>Elternteil</option>
                                                <option>Mitarbeiter</option>
                                                <option>Gesellschafter</option>
                                            </select>
                                            <button @onclick='() => _assistPersons.Remove(p)' style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:16px;padding:0 4px;" title="Entfernen">×</button>
                                        </div>
                                    }
                                </div>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="AddPerson">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    @(AppLoc.Current=="de"?"Person hinzufügen":"Add person")
                                </button>
                            }
                            else if (_promptStep == 3)
                            {
                                <!-- SCHRITT 3: ADRESSEN -->
                                <p class="shint mb-3">@(AppLoc.Current=="de"?"Adressen bestimmen ob ein Dokument zum Mietobjekt gehört und ob Kosten steuerrelevant sind.":"Addresses determine if a document belongs to a rental property and if costs are tax-relevant.")</p>
                                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
                                    @foreach (var a in _assistAddresses)
                                    {
                                        <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;">
                                            <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px;">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="@(a.IsMietobjekt ? "#f59e0b" : "var(--accent)")" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                                <input value="@a.Kurzname" @oninput='e => UpdateAddressKurzname(_assistAddresses.IndexOf(a), e.Value?.ToString() ?? string.Empty)' placeholder="Kurzname (z.B. Zuhause)" style="flex:1;font-size:13px;" />
                                                <select value='@(a.IsMietobjekt ? "Mietobjekt" : "Privatadresse")' @onchange='e => UpdateAddressType(_assistAddresses.IndexOf(a), e.Value?.ToString())' style="font-size:12px;width:auto;">
                                                    <option>Privatadresse</option>
                                                    <option>Mietobjekt</option>
                                                    <option>@(AppLoc.Current=="de"?"Zweitwohnung":"Second home")</option>
                                                    <option>@(AppLoc.Current=="de"?"Büro/Gewerbe":"Office/Business")</option>
                                                </select>
                                                <button @onclick='() => _assistAddresses.Remove(a)' style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:16px;padding:0 4px;" title="Entfernen">×</button>
                                            </div>
                                            <input value="@a.Adresse" @oninput='e => UpdateAddressAdresse(_assistAddresses.IndexOf(a), e.Value?.ToString() ?? string.Empty)' placeholder="Vollständige Adresse (z.B. Musterstr. 1, 12345 Stadt)" style="width:100%;font-size:12px;" />
                                        </div>
                                    }
                                </div>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="AddAddress">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    @(AppLoc.Current=="de"?"Adresse hinzufügen":"Add address")
                                </button>
                            }
                            else if (_promptStep == 4)
                            {
                                <!-- SCHRITT 4: FAHRZEUGE -->
                                <p class="shint mb-3">@(AppLoc.Current=="de"?"Fahrzeuge für Kfz-Steuer, TÜV, Versicherung und Leasing-Erkennung. Optional: Fahrzeug einer Person zuordnen.":"Vehicles for vehicle tax, MOT, insurance and leasing detection. Optional: assign a vehicle to a person.")</p>
                                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
                                    @foreach (var v in _assistVehicles)
                                    {
                                        var vi = _assistVehicles.IndexOf(v);
                                        <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;">
                                            <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px;">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                                <input value="@v.Modell" @oninput='e => UpdateVehicleModell(vi, e.Value?.ToString() ?? "")' placeholder="Marke / Modell (z.B. VW Golf)" style="flex:1;font-size:13px;" />
                                                <button @onclick='() => _assistVehicles.Remove(v)' style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:16px;padding:0 4px;" title="Entfernen">×</button>
                                            </div>
                                            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                                <input value="@v.Kennzeichen" @oninput='e => UpdateVehicleKennzeichen(vi, e.Value?.ToString() ?? "")' placeholder="Kennzeichen (z.B. MS-AB-123)" style="flex:1;min-width:120px;font-size:12px;" />
                                                <select style="flex:1;min-width:120px;font-size:12px;" value="@v.PersonName" @onchange='e => UpdateVehiclePerson(vi, e.Value?.ToString() ?? "")'>
                                                    <option value="">— Keine Person —</option>
                                                    @foreach (var p in _assistPersons.Where(p => !string.IsNullOrWhiteSpace(p.Name)))
                                                    {
                                                        <option value="@p.Name">@p.Name</option>
                                                    }
                                                </select>
                                                <label style="display:flex;align-items:center;gap:5px;font-size:12px;white-space:nowrap;cursor:pointer;">
                                                    <input type="checkbox" checked="@v.IsLeasing" @onchange='e => UpdateVehicleLeasing(vi, (bool)(e.Value ?? false))' />
                                                    Leasing
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick="AddVehicle">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    @(AppLoc.Current=="de"?"Fahrzeug hinzufügen":"Add vehicle")
                                </button>
                                @if (!_assistVehicles.Any())
                                {
                                    <p class="shint mt-2">@(AppLoc.Current=="de"?"Keine Fahrzeuge — Kfz-Dokumente werden trotzdem erkannt, aber ohne Kennzeichen-Zuordnung.":"No vehicles — vehicle documents will still be detected, but without license plate assignment.")</p>
                                }
                            }
                            else if (_promptStep == 5)
                            {
                                <!-- SCHRITT 5: ARBEITGEBER & BERUF -->
                                <p class="shint mb-3">Verknüpfe Arbeitgeber mit Personen aus Schritt 2. Die KI ordnet Gehaltsabrechnungen und Dienstreisen der richtigen Person zu.</p>
                                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
                                    @foreach (var ag in _assistArbeitgeber)
                                    {
                                        var ai = _assistArbeitgeber.IndexOf(ag);
                                        <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;">
                                            <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px;">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                                <input value="@ag.Firma" @oninput='e => UpdateAG(ai, e.Value?.ToString() ?? "")' placeholder="Firmenname (z.B. Musterfirma GmbH)" style="flex:1;font-size:13px;" />
                                                @if (_assistArbeitgeber.Count > 1)
                                                {
                                                    <button @onclick='() => _assistArbeitgeber.Remove(ag)' style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:16px;padding:0 4px;" title="Entfernen">×</button>
                                                }
                                            </div>
                                            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                                <select style="flex:1;min-width:140px;font-size:12px;" value="@ag.PersonName" @onchange='e => UpdateAGPerson(ai, e.Value?.ToString() ?? "")'>
                                                    <option value="">— Person zuordnen —</option>
                                                    @foreach (var p in _assistPersons.Where(p => !string.IsNullOrWhiteSpace(p.Name)))
                                                    {
                                                        <option value="@p.Name">@p.Name (@p.Role)</option>
                                                    }
                                                </select>
                                                <label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer;white-space:nowrap;">
                                                    <input type="checkbox" checked="@ag.Selbststaendig" @onchange='e => UpdateAGSelbst(ai, (bool)(e.Value ?? false))' />
                                                    Selbstständig / Nebengewerbe
                                                </label>
                                            </div>
                                            @if (ag.FruehereArbeitgeber is not null)
                                            {
                                                <input value="@ag.FruehereArbeitgeber" @oninput='e => UpdateAGFrueher(ai, e.Value?.ToString() ?? "")' placeholder="Frühere Arbeitgeber (kommagetrennt)" style="width:100%;font-size:12px;margin-top:6px;" />
                                            }
                                            else
                                            {
                                                <button class="btn secondary !py-0.5 !text-xs !px-2" style="margin-top:6px;" @onclick='() => UpdateAGFrueher(ai, "")'>+ Frühere Arbeitgeber</button>
                                            }
                                        </div>
                                    }
                                </div>
                                <button class="btn secondary !py-1.5 !text-sm" @onclick='() => _assistArbeitgeber.Add(new AssistArbeitgeber(""))'>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    Weiteren Arbeitgeber hinzufügen
                                </button>
                            }
                            else if (_promptStep == 6)
                            {
                                <!-- SCHRITT 6: STEUER (regelbasiert) -->
                                <p class="shint mb-3">Diese Auswahl erzeugt konkrete IF-THEN-Regeln im Prompt — nicht nur Kategorien.</p>
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;">
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxHandwerker" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Handwerker / §35a</div><div style="font-size:11px;color:var(--muted);">Rechnungen von Handwerkern im Privathaushalt</div></div>
                                    </label>
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxWerbungskosten" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Werbungskosten</div><div style="font-size:11px;color:var(--muted);">Arbeitsmittel, Homeoffice, Fortbildung</div></div>
                                    </label>
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxVermietung" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Vermietungskosten</div><div style="font-size:11px;color:var(--muted);">Kosten und Einnahmen Mietobjekte</div></div>
                                    </label>
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxVersicherung" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Versicherungen</div><div style="font-size:11px;color:var(--muted);">Kranken-, Lebens-, Rentenversicherung</div></div>
                                    </label>
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxSpenden" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Spenden</div><div style="font-size:11px;color:var(--muted);">Zuwendungsbestätigungen</div></div>
                                    </label>
                                    <label style="display:flex;align-items:flex-start;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;">
                                        <input type="checkbox" @bind="_taxKirche" style="margin-top:2px;" />
                                        <div><div style="font-size:12px;font-weight:500;">Kirchensteuer</div><div style="font-size:11px;color:var(--muted);">Kirchensteuerbescheide</div></div>
                                    </label>
                                </div>
                                <div style="padding:8px 12px;background:rgba(29,158,117,.06);border-radius:8px;border:1px solid rgba(29,158,117,.15);font-size:11px;color:var(--muted);">
                                    <strong style="color:var(--accent);">Generierte Regel:</strong> Steuer = ja WENN: @(BuildTaxRulePreview())
                                </div>
                                <div style="margin-top:10px;" class="sfield">
                                    <label>Währung (für Rechnungsbetrag-Feld)</label>
                                    <select @bind="_promptCurrency" style="width:auto;">
                                        <option value="EUR">EUR – Euro</option>
                                        <option value="CHF">CHF – Schweizer Franken</option>
                                        <option value="USD">USD – US-Dollar</option>
                                        <option value="GBP">GBP – Britisches Pfund</option>
                                    </select>
                                </div>
                            }
                            else if (_promptStep == 7)
                            {
                                <!-- SCHRITT 7: KORRESPONDENTEN & BEHÖRDEN -->
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                                    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;">
                                        <p style="font-size:12px;font-weight:500;margin:0 0 4px;">Vertragstypen</p>
                                        <p style="font-size:11px;color:var(--muted);margin:0 0 8px;">Verbessert Erkennung von Laufzeiten</p>
                                        <div style="display:flex;flex-direction:column;gap:5px;">
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtStrom" /> Strom / Gas</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtInternet" /> Internet / Telefon</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtVers" /> Versicherungen</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtKV" /> Krankenversicherung</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtMiete" /> Mietverträge</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtLeasing" /> Leasing / Kredit</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtAlters" /> Altersvorsorge</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_vtWartung" /> Wartungsverträge</label>
                                        </div>
                                    </div>
                                    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;">
                                        <p style="font-size:12px;font-weight:500;margin:0 0 4px;">Behörden</p>
                                        <p style="font-size:11px;color:var(--muted);margin:0 0 8px;">Verbessert Korrespondenten-Erkennung</p>
                                        <div style="display:flex;flex-direction:column;gap:5px;">
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhFinanz" /> Finanzamt</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhKK" /> Krankenkasse</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhRente" /> Rentenversicherung</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhStadt" /> Stadtverwaltung</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhGericht" /> Gericht / Notar</label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;"><input type="checkbox" @bind="_bhIHK" /> Handwerkskammer / IHK</label>
                                        </div>
                                        <div style="margin-top:8px;" class="sfield">
                                            <label>Weitere Dienstleister (optional)</label>
                                            <input @bind="_bhDienstleister" placeholder="z.B. Hausarzt, Steuerberater" style="font-size:12px;" />
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (_promptStep == 8)
                            {
                                <!-- SCHRITT 8: TITEL-BUILDER -->
                                <p class="shint mb-3">Klicke Bausteine an um sie zum Titel hinzuzufügen oder zu entfernen. Verschiebe die Reihenfolge mit den Pfeilen.</p>

                                <!-- Vorschau -->
                                <div style="padding:10px 14px;background:rgba(29,158,117,.06);border:1px solid rgba(29,158,117,.2);border-radius:8px;margin-bottom:14px;">
                                    <p style="font-size:10px;color:var(--c-muted);margin:0 0 4px;text-transform:uppercase;letter-spacing:.06em;">Vorschau</p>
                                    <p style="font-size:13px;font-weight:600;color:var(--c-text);margin:0;">
                                        @string.Join(_titelTrennzeichen, _titelBausteine.Select(b => $"[{b}]"))
                                    </p>
                                    <p style="font-size:11px;color:var(--c-muted);margin:4px 0 0;">
                                        Beispiel: @string.Join(_titelTrennzeichen, _titelBausteine.Select(b => b switch {
                                            "Korrespondent" => "Musterfirma",
                                            "Dokumenttyp" => "Rechnung",
                                            "Datum" => "2025-03",
                                            "Betrag" => "149,90 €",
                                            "Rechnungsnummer" => "RE-2025-001",
                                            "Belegnummer" => "BEL-001",
                                            "Beschreibung" => "Wartungsvertrag",
                                            "Fahrzeug" => "VW Golf",
                                            "Kennzeichen" => "MS-AB-123",
                                            _ => b
                                        }))
                                    </p>
                                </div>

                                <!-- Aktive Bausteine -->
                                <p style="font-size:11px;font-weight:600;color:var(--c-text);margin:0 0 6px;">@(AppLoc.Current=="de"?"Aktive Bausteine (Reihenfolge = Titel-Reihenfolge)":"Active blocks (order = title order)")</p>
                                <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px;">
                                    @for (int bi = 0; bi < _titelBausteine.Count; bi++)
                                    {
                                        var bIdx = bi;
                                        var bName = _titelBausteine[bi];
                                        <div style="display:flex;align-items:center;gap:6px;background:var(--c-accent-t);border:1px solid rgba(29,158,117,.25);border-radius:7px;padding:7px 10px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--c-accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                                            <span style="font-size:12px;font-weight:600;color:var(--c-accent);flex:1;">@bName</span>
                                            <button @onclick='() => { if(bIdx > 0) { var t=_titelBausteine[bIdx-1]; _titelBausteine[bIdx-1]=_titelBausteine[bIdx]; _titelBausteine[bIdx]=t; } }' disabled="@(bIdx == 0)" style="background:none;border:none;cursor:pointer;color:var(--c-muted);padding:2px 4px;font-size:14px;" title="Nach oben">▲</button>
                                            <button @onclick='() => { if(bIdx < _titelBausteine.Count-1) { var t=_titelBausteine[bIdx+1]; _titelBausteine[bIdx+1]=_titelBausteine[bIdx]; _titelBausteine[bIdx]=t; } }' disabled="@(bIdx == _titelBausteine.Count-1)" style="background:none;border:none;cursor:pointer;color:var(--c-muted);padding:2px 4px;font-size:14px;" title="Nach unten">▼</button>
                                            <button @onclick='() => _titelBausteine.Remove(bName)' style="background:none;border:none;cursor:pointer;color:var(--c-muted);font-size:16px;padding:0 4px;" title="Entfernen">×</button>
                                        </div>
                                    }
                                </div>

                                <!-- Verfügbare Bausteine -->
                                <p style="font-size:11px;font-weight:600;color:var(--c-text);margin:0 0 6px;">@(AppLoc.Current=="de"?"Verfügbare Bausteine (klicken zum Hinzufügen)":"Available blocks (click to add)")</p>
                                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;">
                                    @foreach (var b in AlleTitelBausteine.Where(b => !_titelBausteine.Contains(b)))
                                    {
                                        var bCopy = b;
                                        <button @onclick='() => _titelBausteine.Add(bCopy)' style="padding:5px 12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:6px;font-size:12px;color:var(--c-muted);cursor:pointer;transition:all .12s;" onmouseover="this.style.borderColor='rgba(29,158,117,.4)';this.style.color='var(--c-accent)'" onmouseout="this.style.borderColor='rgba(255,255,255,.1)';this.style.color='var(--c-muted)'">
                                            + @b
                                        </button>
                                    }
                                    @if (!AlleTitelBausteine.Except(_titelBausteine).Any())
                                    {
                                        <p style="font-size:11px;color:var(--c-muted);margin:0;">Alle Bausteine sind aktiv.</p>
                                    }
                                </div>

                                <!-- Trennzeichen -->
                                <div class="sfield">
                                    <label>@(AppLoc.Current=="de"?"Trennzeichen zwischen Bausteinen":"Separator between blocks")</label>
                                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                        @foreach (var tz in new[]{ " – ", " · ", " - ", " | ", " / " })
                                        {
                                            var tzCopy = tz;
                                            <button @onclick='() => _titelTrennzeichen = tzCopy' style="padding:5px 12px;background:@(_titelTrennzeichen == tz ? "rgba(29,158,117,.15)" : "rgba(255,255,255,.04)");border:1px solid @(_titelTrennzeichen == tz ? "rgba(29,158,117,.4)" : "rgba(255,255,255,.1)");border-radius:6px;font-size:12px;color:@(_titelTrennzeichen == tz ? "var(--c-accent)" : "var(--c-muted)");cursor:pointer;">
                                                A@(tz)B
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                            else if (_promptStep == 9)
                            {
                                <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:12px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                                        <span style="font-size:13px;font-weight:500;">Prompt-Qualität</span>
                                        <span style="font-size:14px;font-weight:600;color:var(--accent);">@(QScorePct)%</span>
                                    </div>
                                    <div style="height:6px;background:var(--border);border-radius:999px;overflow:hidden;margin-bottom:12px;">
                                        <div style="width:@(QScorePct)%;height:100%;background:var(--accent);border-radius:999px;transition:width .4s;"></div>
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:5px;">
                                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                            @if (QPersons) { <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg> } else { <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> }
                                            <span style="color:@(QPersons ? "var(--text)" : "#f59e0b");">@(_assistPersons.Count) @(QPersons ? "Personen definiert" : "Personen fehlen — Familienmitglied-Feld ungenauer")</span>
                                        </div>
                                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                            @if (QAddresses) { <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg> } else { <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> }
                                            <span style="color:@(QAddresses ? "var(--text)" : "#f59e0b");">@(_assistAddresses.Count) @(QAddresses ? "Adressen definiert" : "Adressen fehlen — Mietobjekt-Erkennung deaktiviert")</span>
                                        </div>
                                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                            @if (QTax) { <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg> } else { <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> }
                                            <span style="color:@(QTax ? "var(--text)" : "#f59e0b");">@(QTax ? "Steuerregeln definiert" : "Keine Steuerregeln — Steuer-Feld wird nie gesetzt")</span>
                                        </div>
                                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                            @if (QCF) { <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg> } else { <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> }
                                            <span style="color:@(QCF ? "var(--text)" : "#f59e0b");">Custom Fields: @(_cfNames.Count)/13 @(QCF ? "" : "— Schritt 1 erneut aufrufen")</span>
                                        </div>
                                        @if (_assistVehicles.Any())
                                        {
                                            <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
                                                <span>@(_assistVehicles.Count) Fahrzeug(e) definiert</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <p class="shint mb-2">Generierter Prompt — jetzt speichern oder noch anpassen:</p>
                                <textarea @bind="_generatedPrompt" rows="10" style="font-family:monospace;font-size:11px;width:100%;"></textarea>
                                <div class="saction" style="margin-top:10px;">
                                    <button class="btn" @onclick="SaveGeneratedPrompt">Prompt speichern und aktivieren</button>
                                    <button class="btn secondary" @onclick="() => _promptStep = 1">Von vorne</button>
                                </div>
                                @if (_promptSaved) { <p class="shint" style="color:var(--accent);margin-top:6px;">Prompt gespeichert und aktiv.</p> }
                            }

                        </div>
                    </div>

                    <div class="save-row">
                        @if (_promptStep > 1)
                        {
                            <button class="btn secondary !py-1.5 !text-sm" @onclick="() => _promptStep--">← Zurück</button>
                        }
                        @if (_promptStep < 9)
                        {
                            <button class="btn !py-1.5 !text-sm" @onclick="AdvancePromptStep">Weiter →</button>
                        }
                        @if (_promptStep == 9 && !string.IsNullOrWhiteSpace(_generatedPrompt))
                        {
                            <button class="btn" @onclick="SaveGeneratedPrompt" style="background:var(--c-accent);color:#fff;font-weight:700;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:6px;"><polyline points="20 6 9 17 4 12"/></svg>
                                Prompt speichern & aktivieren
                            </button>
                        }
                        <span style="font-size:11px;color:var(--muted);margin-left:auto;">Schritt @_promptStep von 9</span>
                    </div>

                    <div class="sgroup" style="margin-top:8px;">
                        <p class="stitle">@(AppLoc.Current=="de"?"System-Prompt (direkte Bearbeitung)":"System Prompt (direct editing)")</p>
                        <div class="sbox">
                            @if (_promptContainsPersonalData)
                            {
                                <div class="warn-hint" style="display:flex;align-items:center;gap:6px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;flex-shrink:0;" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> Prompt enthält ggf. persönliche Daten. <button class="btn secondary !py-0.5 !px-2 !text-xs ml-2" @onclick="ClearPersonalData">Leeren</button></div>
                            }
                            <p class="shint mb-2">Leer = Standard-Prompt. Platzhalter: <code>[tags]</code>, <code>[document_types]</code>.</p>
                            <textarea @bind="_settings.CustomSystemPrompt" rows="8" style="font-family:monospace;font-size:12px;width:100%;"
                                      placeholder="Leer lassen für Standard. Oder via Assistent oben generieren."></textarea>
                        </div>
                    </div>
                }


                @if (SettingsTabState.ActiveTab == "Dokument testen")
                {
                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Dokument testen":"Test Document")</p>
                        <div class="sbox !p-0 overflow-hidden" style="min-height:480px;">
                            <TestProcessing />
                        </div>
                    </div>
                }

                @if (SettingsTabState.ActiveTab == "Löschaktionen")
                {
                    <!-- SICHER: Batch-Operationen -->
                    <div class="sgroup">
                        <p class="stitle">@(AppLoc.Current=="de"?"Batch-Operationen":"Batch Operations")</p>

                        <!-- Batch zurücksetzen -->
                        <div class="sbox" style="margin-bottom:10px;">
                            <div style="display:flex;align-items:flex-start;gap:12px;">
                                <div style="padding:8px;background:rgba(29,158,117,.1);border-radius:8px;flex-shrink:0;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.8" style="width:18px;height:18px;" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                                </div>
                                <div style="flex:1;">
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                        <span style="font-size:13px;font-weight:500;">Batch zurücksetzen</span>
                                        <span style="font-size:10px;padding:1px 7px;border-radius:999px;background:rgba(29,158,117,.1);color:var(--accent);border:1px solid rgba(29,158,117,.2);">@(AppLoc.Current=="de"?"Kein Datenverlust":"No data loss")</span>
                                    </div>
                                    <p style="font-size:12px;color:var(--muted);margin:0 0 6px;">@(AppLoc.Current=="de"?"Entfernt den KI-Verarbeitungs-Tag von allen Dokumenten. paperLeo verarbeitet beim nächsten Scan alle Dokumente erneut.":"Removes the AI processing tag from all documents. paperLeo will re-process all documents on the next scan.")</p>
                                    <p style="font-size:11px;color:var(--muted);margin:0 0 8px;"><strong>@(AppLoc.Current=="de"?"Wann sinnvoll":"When useful"):</strong> @(AppLoc.Current=="de"?"Nach einer Prompt-Änderung, neuen Regeln oder wenn du alle Dokumente neu klassifizieren möchtest.":"After a prompt change, new rules, or when you want to re-classify all documents.")</p>
                                    <button class="btn secondary !py-1.5 !text-sm" disabled="@_resetting" @onclick="() => _confirmResetIndex?.Show()">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                                        @(_resetting ?(AppLoc.Current=="de"?"Setze zurück …":"Resetting …") : (AppLoc.Current=="de"?"Batch zurücksetzen":"Reset batch"))
                                    </button>
                                    @if (_resetResult is not null) { <span class="badge @(_resetResult.Success ? "ok" : "error") ml-2">@(_resetResult.Success ? $"{_resetResult.ResetCount} Dokumente zurückgesetzt" : _resetResult.Message)</span> }
                                </div>
                            </div>
                        </div>

                        <!-- Custom Fields nachpflegen -->
                        <div class="sbox">
                            <div style="display:flex;align-items:flex-start;gap:12px;">
                                <div style="padding:8px;background:rgba(99,102,241,.1);border-radius:8px;flex-shrink:0;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.8" style="width:18px;height:18px;" aria-hidden="true"><path d="M12 6V4m0 2a2 2 0 1 0 0 4m0-4a2 2 0 1 1 0 4m-6 8a2 2 0 1 0 0-4m0 4a2 2 0 1 1 0-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 1 0 0-4m0 4a2 2 0 1 1 0-4m0 4v2m0-6V4"/></svg>
                                </div>
                                <div style="flex:1;">
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                        <span style="font-size:13px;font-weight:500;">@(AppLoc.Current=="de"?"Custom Fields nachpflegen":"Backfill custom fields")</span>
                                        <span style="font-size:10px;padding:1px 7px;border-radius:999px;background:rgba(99,102,241,.1);color:#6366f1;border:1px solid rgba(99,102,241,.2);">@(AppLoc.Current=="de"?"Sanfte Nachpflege":"Gentle backfill")</span>
                                    </div>
                                    <p style="font-size:12px;color:var(--muted);margin:0 0 6px;">@(AppLoc.Current=="de"?"Befüllt leere Custom Fields bei bereits verarbeiteten Dokumenten nach — Titel, Tags und Korrespondent bleiben unverändert.":"Fills empty custom fields on already processed documents — title, tags and correspondent remain unchanged.")</p>
                                    <p style="font-size:11px;color:var(--muted);margin:0 0 8px;"><strong>@(AppLoc.Current=="de"?"Wann sinnvoll":"When useful"):</strong> @(AppLoc.Current=="de"?"Nachdem du neue Custom Fields in Paperless angelegt hast und diese bei bestehenden Dokumenten ergänzen möchtest.":"After creating new custom fields in Paperless and wanting to populate them on existing documents.")</p>
                                    @if (_backfillProgress?.IsRunning == true)
                                    {
                                        <div style="margin-bottom:8px;">
                                            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;">
                                                <span style="color:var(--muted);">@_backfillProgress.Current von @_backfillProgress.Total</span>
                                                <span style="color:var(--muted);">@_backfillProgress.Updated aktualisiert</span>
                                            </div>
                                            <div style="height:4px;background:var(--border);border-radius:999px;overflow:hidden;">
                                                @if (_backfillProgress.Total > 0) { var pct2 = (int)(_backfillProgress.Current * 100.0 / _backfillProgress.Total); <div style="width:@(pct2)%;height:100%;background:#6366f1;border-radius:999px;transition:width 0.4s;"></div> }
                                            </div>
                                        </div>
                                    }
                                    <button class="btn secondary !py-1.5 !text-sm" @onclick="StartBackfill" disabled="@(_backfillProgress?.IsRunning == true)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;" aria-hidden="true"><path d="M12 6V4m0 2a2 2 0 1 0 0 4m0-4a2 2 0 1 1 0 4"/></svg>
                                        @(_backfillProgress?.IsRunning == true ?(AppLoc.Current=="de"?"Läuft …":"Running …") : (AppLoc.Current=="de"?"Nachpflegen starten":"Start backfill"))
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- UNWIDERRUFLICH: Löschaktionen -->
                    <div class="sgroup">
                        <p class="stitle" style="color:var(--danger);display:flex;align-items:center;gap:6px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:14px;height:14px;" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            @(AppLoc.Current=="de"?"Unwiderrufliche Aktionen":"Irreversible Actions")
                        </p>
                        <div style="background:rgba(239,68,68,.04);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:12px;margin-bottom:10px;">
                            <p style="font-size:12px;color:rgba(239,68,68,.8);margin:0;display:flex;align-items:center;gap:6px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:13px;height:13px;flex-shrink:0;" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                                @(AppLoc.Current=="de"?"Betrifft das GESAMTE Paperless-System. Bitte vorher ein Backup erstellen. Diese Aktionen können nicht rückgängig gemacht werden.":"Affects the ENTIRE Paperless system. Please create a backup first. These actions cannot be undone.")
                            </p>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                            <div class="sbox">
                                <div style="display:flex;gap:10px;align-items:flex-start;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;margin-top:2px;" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                    <div>
                                        <p style="font-size:12px;font-weight:500;margin:0 0 3px;">@(AppLoc.Current=="de"?"Tags löschen":"Delete tags")</p>
                                        <p style="font-size:11px;color:var(--muted);margin:0 0 8px;">@(AppLoc.Current=="de"?"Entfernt alle Tags aus Paperless. Dokumente verlieren ihre Tag-Zuordnungen.":"Removes all tags from Paperless. Documents will lose their tag assignments.")</p>
                                        <button class="del-btn" disabled="@_deletingTags" @onclick="() => _confirmTags?.Show()">@(_deletingTags ?(AppLoc.Current=="de"?"Lösche …":"Deleting …") : (AppLoc.Current=="de"?"Tags löschen":"Delete tags"))</button>
                                        @if (_deleteTagsResult is not null) { <p class="shint mt-1">@(_deleteTagsResult.Success ? $"{_deleteTagsResult.DeletedCount} gelöscht" : _deleteTagsResult.Message)</p> }
                                    </div>
                                </div>
                            </div>
                            <div class="sbox">
                                <div style="display:flex;gap:10px;align-items:flex-start;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.8" style="width:16px;height:16px;flex-shrink:0;margin-top:2px;" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
                                    <div>
