<!-- ConfirmDialoge global am Ende der Komponente - NICHT innerhalb von Tab-Content-Blöcken -->
<ConfirmDialog @ref="_confirmTags" Title="Alle Tags löschen"
    Text="Alle Tags werden unwiderruflich aus Paperless gelöscht. Dokumente verlieren ihre Tags. Bitte vorher ein Backup erstellen."
    ConfirmLabel="Alle Tags löschen" TypeToConfirm="LÖSCHEN"
    OnConfirmed="DeleteAllTagsConfirmed" />
<ConfirmDialog @ref="_confirmDocTypes" Title="Alle Dokumenttypen löschen"
    Text="Alle Dokumenttypen werden unwiderruflich aus Paperless gelöscht."
    ConfirmLabel="Alle Dokumenttypen löschen" TypeToConfirm="LÖSCHEN"
    OnConfirmed="DeleteAllDocTypesConfirmed" />
<ConfirmDialog @ref="_confirmCorrespondents" Title="Alle Korrespondenten löschen"
    Text="Alle Korrespondenten werden unwiderruflich aus Paperless gelöscht."
    ConfirmLabel="Alle Korrespondenten löschen" TypeToConfirm="LÖSCHEN"
    OnConfirmed="DeleteAllCorrespondentsConfirmed" />
<ConfirmDialog @ref="_confirmFullReset" Title="Kompletter Reset"
    Text="Tags, Dokumenttypen UND Korrespondenten werden alle gelöscht. Diese Aktion ist nicht umkehrbar."
