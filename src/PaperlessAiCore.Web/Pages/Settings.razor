    private async Task ApplyArchiveImportAsync()
    {
        if (_archiveImportChecked) return;
        _archiveImportChecked = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("sessionStorage.getItem", "archiveAnalysisImport");
            if (string.IsNullOrWhiteSpace(json)) return;

            var fields = System.Text.Json.JsonSerializer.Deserialize<List<ArchiveField>>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (fields is null || !fields.Any()) return;

            // Initialliste leeren wenn nur Leereinträge drin
            if (_assistPersons.All(p => string.IsNullOrWhiteSpace(p.Name)))
                _assistPersons.Clear();
            if (_assistAddresses.All(a => string.IsNullOrWhiteSpace(a.Adresse)))
                _assistAddresses.Clear();
            if (_assistArbeitgeber.All(a => string.IsNullOrWhiteSpace(a.Firma)))
                _assistArbeitgeber.Clear();

            foreach (var f in fields)
            {
                switch (f.Key)
                {
                    case "name":
                        if (!string.IsNullOrWhiteSpace(f.Value) && _assistPersons.All(p => p.Name != f.Value))
                            _assistPersons.Add(new AssistPerson(f.Value, "Hauptnutzer"));
                        break;
                    case "adresse":
                        if (!string.IsNullOrWhiteSpace(f.Value) && _assistAddresses.All(a => a.Adresse != f.Value))
                            _assistAddresses.Add(new AssistAddress("Adresse", f.Value, false));
                        break;
                    case "firma":
                        if (!string.IsNullOrWhiteSpace(f.Value) && _assistArbeitgeber.All(a => a.Firma != f.Value))
                            _assistArbeitgeber.Add(new AssistArbeitgeber(f.Value));
                        break;
                    case "modell":
                        if (!string.IsNullOrWhiteSpace(f.Value) && _assistVehicles.All(v => v.Modell != f.Value))
                            _assistVehicles.Add(new AssistVehicle(f.Value, "", false));
                        break;
                    case "kennzeichen":
                        if (!string.IsNullOrWhiteSpace(f.Value))
                        {
                            var noKz = _assistVehicles.FindIndex(v => string.IsNullOrWhiteSpace(v.Kennzeichen));
                            if (noKz >= 0) _assistVehicles[noKz] = _assistVehicles[noKz] with { Kennzeichen = f.Value };
                            else _assistVehicles.Add(new AssistVehicle("", f.Value, false));
                        }
                        break;
                    case "steuernummer": _archiveExtraInfo.TryAdd("Steuernummer", f.Value); break;
                    case "steuer_id":    _archiveExtraInfo.TryAdd("Steuer-ID", f.Value); break;
                    case "rentenversicherungsnr": _archiveExtraInfo.TryAdd("Rentenversicherungsnr.", f.Value); break;
                    case "iban":         _archiveExtraInfo.TryAdd($"IBAN", f.Value); break;
                    case "krankenversicherung": _archiveExtraInfo.TryAdd("Krankenversicherung", f.Value); break;
                    case "finanzamt":    _archiveExtraInfo.TryAdd("Finanzamt", f.Value); break;
                }
            }

            await JS.InvokeVoidAsync("sessionStorage.removeItem", "archiveAnalysisImport");
            _archiveImportDone = true;
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private Dictionary<string, string> _archiveExtraInfo = new();
