        _importingTagsFromPaperless = true; StateHasChanged();
        var result = await Api.ImportTagsFromPaperlessAsync();
        if (result.Success && !string.IsNullOrEmpty(result.SuggestedVocabulary))
        {
            _settings.DefaultTagVocabulary = result.SuggestedVocabulary;
            _suggestTagsResult = new SuggestVocabularyResult { Success = true, Message = $"✓ {result.DocumentsAnalyzed} Tags aus Paperless importiert", SuggestedVocabulary = result.SuggestedVocabulary };
        }
        else { _suggestTagsResult = new SuggestVocabularyResult { Success = false, Message = result.Message ?? "Fehler beim Import" }; }
        _importingTagsFromPaperless = false;
    }
