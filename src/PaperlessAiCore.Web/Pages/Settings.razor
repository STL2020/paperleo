    private void BuildPrompt()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Du bist ein präziser KI-Archivar für ein deutsches Privatarchiv. Deine Aufgabe ist die vollständige Metadatenextraktion aus Dokumenten.");
        sb.AppendLine();
        sb.AppendLine("AUSGABE: Antworte AUSSCHLIESSLICH mit einem validen JSON-Objekt. Kein Text davor oder danach. Kein Markdown.");
        sb.AppendLine();
        sb.AppendLine("JSON-SCHEMA (alle Felder immer ausgeben, fehlende Werte als null):");
        sb.AppendLine("{");
        sb.AppendLine("  \"title\": \"Prägnanter Dokumenttitel (max. 60 Zeichen, deutsch)\",");
        sb.AppendLine("  \"created\": \"YYYY-MM-DD oder null\",");
        sb.AppendLine("  \"correspondent\": \"Markenname ohne Rechtsform (GmbH/AG/e.V. weglassen) oder null\",");
        sb.AppendLine("  \"document_type\": \"Aus Liste [document_types] wählen oder null\",");
        sb.AppendLine("  \"tags\": [\"Aus Liste [tags] wählen\"],");
        sb.AppendLine("  \"custom_fields\": {");
        sb.AppendLine("    \"Rechnungsnummer\": \"String oder null\",");
        sb.AppendLine("    \"Belegnummer\": \"String oder null\",");
        sb.AppendLine("    \"Rechnungsbetrag\": \"Zahl mit Punkt als Dezimaltrennzeichen z.B. 1234.56 oder null\",");
        sb.AppendLine("    \"Seriennummer\": \"String oder null\",");
        sb.AppendLine("    \"Fahrzeug\": \"Marke Modell (Kennzeichen) oder null\",");
        sb.AppendLine("    \"Gewerk_Dienstleistung\": \"Art der Handwerksleistung oder null\",");
        sb.AppendLine("    \"Objekt / Adresse\": \"Adresse aus ADRESSEN-Liste oder null\",");
        sb.AppendLine("    \"Familienmitglied\": \"Name aus PERSONEN-Liste oder null\",");
        sb.AppendLine("    \"Vertragsende\": \"YYYY-MM-DD oder null\",");
        sb.AppendLine("    \"Vertragsnummer\": \"String oder null\",");
        sb.AppendLine("    \"Fälligkeitsdatum\": \"YYYY-MM-DD oder null\",");
        sb.AppendLine("    \"Steuer\": true/false,");
        sb.AppendLine("    \"Mietobjekt\": true/false");
        sb.AppendLine("  }");
        sb.AppendLine("}");
        sb.AppendLine();
        sb.AppendLine("KORRESPONDENTEN-REGELN:");
        sb.AppendLine("- Immer Markenname, nie Rechtsform: 'Telekom' nicht 'Deutsche Telekom GmbH'");
        sb.AppendLine("- Behörden vollständig: 'Finanzamt Remagen', 'Krankenkasse TK'");
        sb.AppendLine("- Unbekannter Absender: null (nicht raten)");
        sb.AppendLine();
        sb.AppendLine("TITEL-REGELN:");
        sb.AppendLine("- Format: [Korrespondent] – [Dokumentart] [Datum/Zeitraum]");
        sb.AppendLine("- Beispiele: 'Telekom – Rechnung Jan 2025', 'Finanzamt – Steuerbescheid 2024'");
        sb.AppendLine("- Max. 60 Zeichen, deutsch, keine Abkürzungen");
        sb.AppendLine();
        sb.AppendLine("DATUM-REGELN:");
        sb.AppendLine("- Immer ISO 8601: YYYY-MM-DD");
        sb.AppendLine("- Dokumentdatum = Ausstellungsdatum, nicht Scanndatum");
        sb.AppendLine("- Vertragsende = letzter Gültigkeitstag");
        sb.AppendLine();
        sb.AppendLine("PRIORISIERUNG bei Mehrdeutigkeit:");
        sb.AppendLine("- Steuer=true hat Vorrang wenn Dokument EINDEUTIG steuerrelevant ist");
        sb.AppendLine("- Mietobjekt=true nur wenn Adresse EXAKT einer Mietobjekt-Adresse entspricht");
        sb.AppendLine("- Tags: max. 5, nur wenn eindeutig zutreffend");
        sb.AppendLine();
        sb.AppendLine();

        var persons = _assistPersons.Where(p => !string.IsNullOrWhiteSpace(p.Name)).ToList();
        if (persons.Any())
        {
            sb.AppendLine("PERSONEN (für Feld family_member):");
            foreach (var p in persons)
                sb.AppendLine($"- {p.Name} ({p.Role})");
            var primary = persons.FirstOrDefault(p => p.Role == "Hauptnutzer");
            if (primary != null) sb.AppendLine($"Primärnutzer: {primary.Name}");
            sb.AppendLine();
        }

        var addresses = _assistAddresses.Where(a => !string.IsNullOrWhiteSpace(a.Adresse)).ToList();
        if (addresses.Any())
        {
            sb.AppendLine("ADRESSEN (für Feld property_address und Mietobjekt-Erkennung):");
            foreach (var a in addresses)
                sb.AppendLine($"- {a.Kurzname}: {a.Adresse} → {(a.IsMietobjekt ? "Mietobjekt = ja, Kosten steuerrelevant" : "Privatbesitz")}");
            sb.AppendLine();
        }

        var vehicles = _assistVehicles.Where(v => !string.IsNullOrWhiteSpace(v.Modell)).ToList();
        if (vehicles.Any())
        {
            sb.AppendLine("FAHRZEUGE:");
            foreach (var v in vehicles)
                sb.AppendLine($"- {v.Modell}{(string.IsNullOrWhiteSpace(v.Kennzeichen) ? "" : $" ({v.Kennzeichen})")}{(v.IsLeasing ? " [Leasing]" : "")}");
            sb.AppendLine();
        }

        if (!string.IsNullOrWhiteSpace(_assistArbeitgeber.FirstOrDefault()?.Firma))
        {
            sb.AppendLine("ARBEITGEBER:");
            foreach (var ag in _assistArbeitgeber.Where(a => !string.IsNullOrWhiteSpace(a.Firma)))
            {
                sb.Append($"- {ag.Firma}");
                if (!string.IsNullOrWhiteSpace(ag.PersonName)) sb.Append($" (für {ag.PersonName})");
                if (!string.IsNullOrWhiteSpace(ag.FruehereArbeitgeber)) sb.Append($" · Früher: {ag.FruehereArbeitgeber}");
                if (ag.Selbststaendig) sb.Append(" · Selbstständig/Nebengewerbe");
                sb.AppendLine();
            }
            sb.AppendLine("Gehaltsabrechnungen, Lohnsteuerbescheinigungen und Dienstreise-Belege dem jeweiligen Arbeitgeber zuordnen.");
            sb.AppendLine();
        }

        var taxRules = new List<string>();
        if (_taxHandwerker)    taxRules.Add("Handwerkerleistungen im Privathaushalt (§35a EStG) + Rechnung");
        if (_taxWerbungskosten) taxRules.Add("Arbeitsmittel, Homeoffice, Fortbildung");
        if (_taxVermietung)    taxRules.Add("Kosten oder Einnahmen für Mietobjekte");
        if (_taxVersicherung)  taxRules.Add("Kranken-, Lebens- oder Rentenversicherungsbeiträge");
        if (_taxSpenden)       taxRules.Add("Spendenquittungen und Zuwendungsbestätigungen");
        if (_taxKirche)        taxRules.Add("Kirchensteuerbescheide");
        taxRules.Add("Steuerbescheide direkt vom Finanzamt");
        sb.AppendLine("STEUER-REGELN (Feld is_tax_relevant = true WENN):");
        foreach (var r in taxRules) sb.AppendLine($"- {r}");
        sb.AppendLine($"BETRÄGE: Währung {_promptCurrency}, Format: 1234.56 (Punkt, 2 Dezimalstellen)");
        sb.AppendLine();

        var vts = new List<string>();
        if (_vtStrom) vts.Add("Strom/Gas"); if (_vtInternet) vts.Add("Internet/Telefon");
        if (_vtVers) vts.Add("Versicherungen"); if (_vtKV) vts.Add("Krankenversicherung");
        if (_vtMiete) vts.Add("Mietverträge"); if (_vtLeasing) vts.Add("Leasing/Kredit");
        if (_vtAlters) vts.Add("Altersvorsorge"); if (_vtWartung) vts.Add("Wartungsverträge");
        if (vts.Any()) sb.AppendLine($"VERTRAGSTYPEN (verbessert Laufzeit-Erkennung): {string.Join(", ", vts)}");

        var bhs = new List<string>();
        if (_bhFinanz) bhs.Add("Finanzamt"); if (_bhKK) bhs.Add("Krankenkasse");
        if (_bhRente) bhs.Add("Rentenversicherung"); if (_bhStadt) bhs.Add("Stadtverwaltung");
        if (_bhGericht) bhs.Add("Gericht/Notar"); if (_bhIHK) bhs.Add("Handwerkskammer/IHK");
        if (bhs.Any()) sb.AppendLine($"BEHÖRDEN: {string.Join(", ", bhs)}");
        if (!string.IsNullOrWhiteSpace(_bhDienstleister))
            sb.AppendLine($"DIENSTLEISTER: {_bhDienstleister}");

        sb.AppendLine();
        if (_archiveExtraInfo.Any())
        {
            sb.AppendLine("WEITERE PERSÖNLICHE DATEN:");
            foreach (var kv in _archiveExtraInfo)
                sb.AppendLine($"- {kv.Key}: {kv.Value}");
            sb.AppendLine();
        }
        sb.AppendLine($"TITEL-FORMAT: {string.Join(_titelTrennzeichen, _titelBausteine.Select(b => $"[{b}]"))}");
        sb.AppendLine($"Beispiel: {string.Join(_titelTrennzeichen, _titelBausteine.Select(TitelBeispiel))}");
        sb.AppendLine();
        sb.AppendLine("Tags: [tags]");
        sb.AppendLine("Dokumenttypen: [document_types]");
        _generatedPrompt = sb.ToString().Trim();
    }

