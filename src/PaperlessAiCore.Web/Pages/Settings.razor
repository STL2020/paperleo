    private void ApplyPreset(string p)
    {
        var preset = _providers.FirstOrDefault(x => x.Key == p);
        if (preset is null) return;
        _activeProvider = p;
        _settings.LlmProvider = preset.Provider;
        _settings.LlmModel = preset.DefaultModel;
        _settings.LlmApiBase = preset.ApiBase;
    }

    private async Task Save()
    {
        _saving = true; _savedMessage = null; StateHasChanged();
        // Community-Modus: Vokabular immer auf Defaults zurücksetzen, egal was im UI steht
        if (!_proMode)
        {
            _settings.DefaultTagVocabulary = "Rechnung, Vertrag, Privat, Arbeit, Sonstiges";
            _settings.DefaultDocumentTypeVocabulary = "Rechnung, Vertrag, Anschreiben, Bescheid, Sonstiges";
        }
        await Api.SaveSettingsAsync(_settings);
        _savedMessage = "Gespeichert ✓"; _saving = false;
        await Task.Delay(2500); _savedMessage = null;
    }

