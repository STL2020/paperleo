    private async Task ExportConfig()
    {
        var e = new { _settings.ProcessedTagName, _settings.PollIntervalSeconds, _settings.AutoModeEnabled, _settings.EnableTagsAssignment, _settings.EnableCorrespondentDetection, _settings.EnableDocumentTypeClassification, _settings.EnableTitleGeneration, _settings.UseExistingCorrespondentsOnly, _settings.UseExistingDocumentTypesOnly, _settings.UseExistingTagsOnly, _settings.EnableCustomFields, _settings.DefaultTagVocabulary, _settings.DefaultDocumentTypeVocabulary, _settings.EnabledCustomFieldNames, _settings.CustomSystemPrompt, _settings.LlmTemperature, _settings.LlmMaxTokens, _settings.LlmProvider, _settings.LlmModel, _settings.LlmApiBase, exportedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm") };
        var json = System.Text.Json.JsonSerializer.Serialize(e, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "paperleo-config.json", "application/json", Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json)));
    }

    private async Task ImportConfig(Microsoft.AspNetCore.Components.ChangeEventArgs ev)
    {
        _importMessage = null;
        try
        {
            if (ev.Value is not Microsoft.AspNetCore.Components.Forms.IBrowserFile f) return;
            using var stream = f.OpenReadStream(512 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            using var doc = System.Text.Json.JsonDocument.Parse(await reader.ReadToEndAsync());
            var r = doc.RootElement;
            void S(string p, Action<string?> a) { if (r.TryGetProperty(p, out var v)) a(v.ValueKind == System.Text.Json.JsonValueKind.String ? v.GetString() : null); }
            void B(string p, Action<bool> a) { if (r.TryGetProperty(p, out var v) && v.ValueKind is System.Text.Json.JsonValueKind.True or System.Text.Json.JsonValueKind.False) a(v.GetBoolean()); }
            void I(string p, Action<int> a) { if (r.TryGetProperty(p, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.Number) a(v.GetInt32()); }
            S("processedTagName", v => _settings.ProcessedTagName = v ?? _settings.ProcessedTagName);
            S("defaultTagVocabulary", v => _settings.DefaultTagVocabulary = v);
            S("defaultDocumentTypeVocabulary", v => _settings.DefaultDocumentTypeVocabulary = v);
            S("customSystemPrompt", v => _settings.CustomSystemPrompt = v);
            S("enabledCustomFieldNames", v => _settings.EnabledCustomFieldNames = v);
            S("llmProvider", v => _settings.LlmProvider = v ?? _settings.LlmProvider);
            S("llmModel", v => _settings.LlmModel = v ?? _settings.LlmModel);
            S("llmApiBase", v => _settings.LlmApiBase = v);
            B("autoModeEnabled", v => _settings.AutoModeEnabled = v);
            B("enableTagsAssignment", v => _settings.EnableTagsAssignment = v);
            B("enableCorrespondentDetection", v => _settings.EnableCorrespondentDetection = v);
            B("enableDocumentTypeClassification", v => _settings.EnableDocumentTypeClassification = v);
            B("enableTitleGeneration", v => _settings.EnableTitleGeneration = v);
            B("enableCustomFields", v => _settings.EnableCustomFields = v);
            B("useExistingCorrespondentsOnly", v => _settings.UseExistingCorrespondentsOnly = v);
            B("useExistingDocumentTypesOnly", v => _settings.UseExistingDocumentTypesOnly = v);
            B("useExistingTagsOnly", v => _settings.UseExistingTagsOnly = v);
            I("pollIntervalSeconds", v => _settings.PollIntervalSeconds = v);
            I("llmMaxTokens", v => _settings.LlmMaxTokens = v);
            if (r.TryGetProperty("llmTemperature", out var t)) _settings.LlmTemperature = t.GetDouble();
            _importMessage = "Importiert – bitte speichern.";
        }
        catch (Exception ex) { _importMessage = $"❌ {ex.Message}"; }
    }

    private void ToggleCustomField(string n, bool on)
    {
        var set = (_settings.EnabledCustomFieldNames ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (set.Count == 0) set = _customFields.Select(f => f.Name).Where(x => !string.Equals(x, n, StringComparison.OrdinalIgnoreCase)).ToHashSet(StringComparer.OrdinalIgnoreCase);
        else if (on) set.Add(n); else set.Remove(n);
        _settings.EnabledCustomFieldNames = set.Count == _customFields.Count ? "" : string.Join(", ", set);
    }

    private async Task LoadCustomFields() { _loadingFields = true; StateHasChanged(); _customFields = await Api.GetCustomFieldsAsync(); _loadingFields = false; }

    private async Task CreateCustomField()
    {
        if (string.IsNullOrWhiteSpace(_newFieldName)) return;
        _creatingField = true; _createFieldMessage = null; StateHasChanged();
        var (ok, msg) = await Api.CreateCustomFieldAsync(_newFieldName.Trim(), _newFieldType);
        _createFieldMessage = ok ? $"\"{_newFieldName}\" angelegt." : $"❌ {msg}";
        if (ok) { _newFieldName = ""; await LoadCustomFields(); }
        _creatingField = false;
    }

    private async Task StartBackfill()
    {
        await Api.BackfillCustomFieldsAsync();
        _backfillProgress = new BackfillProgress { IsRunning = true };
        StateHasChanged();
        // Polling alle 1.5s
        _backfillTimer?.Dispose();
        _backfillTimer = new System.Threading.Timer(async _ =>
        {
            var progress = await Api.GetBackfillProgressAsync();
            if (progress is not null) _backfillProgress = progress;
            await InvokeAsync(StateHasChanged);
            if (progress?.IsRunning == false) { _backfillTimer?.Dispose(); _backfillTimer = null; }
        }, null, 1500, 1500);
    }

