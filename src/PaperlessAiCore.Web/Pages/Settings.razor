    private string BuildTaxRulePreview()
    {
        var parts = new List<string>();
        if (_taxHandwerker)    parts.Add("Handwerker-Rechnung im Haushalt");
        if (_taxWerbungskosten) parts.Add("Arbeitsmittel/Homeoffice");
        if (_taxVermietung)    parts.Add("Mietobjekt-Kosten/-Einnahmen");
        if (_taxVersicherung)  parts.Add("Versicherungsbeitrag");
        if (_taxSpenden)       parts.Add("Spendenquittung");
        if (_taxKirche)        parts.Add("Kirchensteuerbescheid");
        return parts.Any() ? string.Join(" ODER ", parts) : "(keine Regeln definiert)";
    }

    private string BuildTaxCategories()
    {
        var cats = new List<string>();
        if (_taxHandwerker)    cats.Add("Handwerkerleistungen §35a EStG");
        if (_taxWerbungskosten) cats.Add("Werbungskosten / berufliche Ausgaben");
        if (_taxSpenden)       cats.Add("Spenden / Zuwendungen");
        if (_taxKirche)        cats.Add("Kirchensteuer");
        if (_taxVermietung)    cats.Add("Vermietungskosten und -einnahmen");
        if (_taxVersicherung)  cats.Add("Versicherungsbeiträge");
        return string.Join(", ", cats);
    }

