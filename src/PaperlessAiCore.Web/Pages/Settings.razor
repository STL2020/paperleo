    private void ApplyPreset(string p)
    {
        var preset = _providers.FirstOrDefault(x => x.Key == p);
        if (preset is null) return;
        _activeProvider = p;
        _settings.LlmProvider = preset.Provider;
        _settings.LlmModel = preset.DefaultModel;
        _settings.LlmApiBase = preset.ApiBase;
    }

    private System.Threading.CancellationTokenSource? _autoSaveCts;

    private Task AutoSaveAsync()
    {
        _autoSaveCts?.Cancel();
        _autoSaveCts = new System.Threading.CancellationTokenSource();
        var token = _autoSaveCts.Token;
        SettingsTabState.SetSaveStatus("saving");
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(1200, token);
                if (!token.IsCancellationRequested)
                {
                    await InvokeAsync(async () =>
                    {
                        await Save();
                        SettingsTabState.SetSaveStatus("saved");
                        StateHasChanged();
                        await Task.Delay(2000);
                        SettingsTabState.SetSaveStatus(null);
                        StateHasChanged();
                    });
                }
            }
            catch (TaskCanceledException)
            {
                await InvokeAsync(() => { SettingsTabState.SetSaveStatus(null); StateHasChanged(); });
            }
        });
        return Task.CompletedTask;
    }

