    .sbox { background: rgba(255,255,255,0.02); border: 0.5px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 14px; }
    .sfield { display: flex; flex-direction: column; gap: 3px; margin-bottom: 10px; }
    .sfield:last-child { margin-bottom: 0; }
    .sfield label { font-size: 11px; font-weight: 500; color: var(--muted); }
    .shint { font-size: 11px; color: var(--muted); margin: 2px 0 0; line-height: 1.4; }
    .saction { display: flex; align-items: center; gap: 8px; margin-top: 8px; flex-wrap: wrap; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 7px 0; border-bottom: 0.5px solid rgba(255,255,255,0.04); }
    .toggle-row:last-child { border-bottom: none; }
    .preset-btn { padding: 5px 10px; font-size: 12px; border: 0.5px solid rgba(255,255,255,0.1); border-radius: 6px; background: rgba(255,255,255,0.03); cursor: pointer; color: var(--text); transition: background 0.12s; display:inline-flex;align-items:center;gap:5px; }
    .preset-btn:hover { background: rgba(255,255,255,0.07); }
    .preset-btn.active { background: rgba(29,158,117,0.12); border-color: rgba(29,158,117,0.3); color: var(--accent); }
    .demo-hint { background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.15); border-radius: 6px; padding: 7px 10px; font-size: 11px; color: #fbbf24; margin-bottom: 8px; }
    .warn-hint { background: rgba(220,38,38,0.08); border: 1px solid rgba(220,38,38,0.15); border-radius: 6px; padding: 7px 10px; font-size: 11px; color: #f87171; margin-bottom: 8px; display: flex; align-items: center; }
    .del-btn { padding: 9px 12px; border-radius: 7px; border: 0.5px solid rgba(220,38,38,0.2); background: rgba(220,38,38,0.04); color: #f87171; cursor: pointer; font-size: 13px; text-align: left; transition: background 0.12s; width: 100%; }
    .del-btn:hover { background: rgba(220,38,38,0.09); }
