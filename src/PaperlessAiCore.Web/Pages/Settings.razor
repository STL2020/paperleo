                            <div style="margin-top:12px;padding:10px;background:rgba(255,255,255,.02);border-radius:8px;text-align:center;">
                                <p style="font-size:11px;color:var(--c-muted);margin:0;">paperLeo @(System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? "5.0") · Standalone, selbst-gehostet · Kein Tracking, keine Cloud</p>
