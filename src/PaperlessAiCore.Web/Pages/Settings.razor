    private async Task CreateCustomField()
    {
        if (string.IsNullOrWhiteSpace(_newFieldName)) return;
        _creatingField = true; _createFieldMessage = null; StateHasChanged();
        var (ok, msg) = await Api.CreateCustomFieldAsync(_newFieldName.Trim(), _newFieldType);
        _createFieldMessage = ok ? $"\"{_newFieldName}\" angelegt." : $"❌ {msg}";
        if (ok) { _newFieldName = ""; await LoadCustomFields(); }
        _creatingField = false;
    }

    private async Task StartBackfill()
    {
        await Api.BackfillCustomFieldsAsync();
        _backfillProgress = new BackfillProgress { IsRunning = true };
        StateHasChanged();
        // Polling alle 1.5s
        _backfillTimer?.Dispose();
        _backfillTimer = new System.Threading.Timer(async _ =>
        {
            var progress = await Api.GetBackfillProgressAsync();
            if (progress is not null) _backfillProgress = progress;
            await InvokeAsync(StateHasChanged);
            if (progress?.IsRunning == false) { _backfillTimer?.Dispose(); _backfillTimer = null; }
        }, null, 1500, 1500);
    }

