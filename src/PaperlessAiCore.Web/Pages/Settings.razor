    private async Task Retry()
    {
        _loading = true; _loadError = null; StateHasChanged();
        await OnInitializedAsync();
    }

    protected override void OnInitialized()
    {
        SettingsTabState.OnChanged += async () =>
        {
            if (SettingsTabState.ActiveTab == "Prompt-Assistent")
            {
                LoadCfNames();
                _archiveImportChecked = false; // erlaubt erneuten Import-Check
                await ApplyArchiveImportAsync();
            }
            await InvokeAsync(StateHasChanged);
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await Api.GetSettingsAsync();
            try { var s = await Api.GetStatusAsync(); _proMode = s.ProMode; } catch { }

            // Community-Modus: Vokabular immer auf Demo-Defaults zurücksetzen
            if (!_proMode)
            {
                _settings.DefaultTagVocabulary = "Rechnung, Vertrag, Privat, Arbeit, Sonstiges";
                _settings.DefaultDocumentTypeVocabulary = "Rechnung, Vertrag, Anschreiben, Bescheid, Sonstiges";
            }
        }
        catch (Exception ex)
        {
            _loadError = $"Einstellungen konnten nicht geladen werden: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
            _ = Task.Run(async () => {
                try { await LoadCustomFields(); } catch { }
                try { await LoadCfNamesAsync(); } catch { }
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task CreateMissingFieldsAsync()
    {
        _creatingMissingFields = true; _setupMessage = ""; StateHasChanged();
        var requiredFields = new[] {
            ("Steuer","boolean"),("Mietobjekt","boolean"),("Rechnungsbetrag","monetary"),
            ("Rechnungsnummer","string"),("Belegnummer","string"),("Seriennummer","string"),
            ("Fahrzeug","string"),("Vertragsnummer","string"),("Vertragsende","date"),
            ("Fälligkeitsdatum","date"),("Gewerk_Dienstleistung","string"),
            ("Objekt / Adresse","string"),("Familienmitglied","string")
        };
        int created = 0;
        foreach (var (name, type) in requiredFields)
        {
            if (!_cfNames.Any(n => string.Equals(n, name, StringComparison.OrdinalIgnoreCase)))
            {
                var (ok, _) = await Api.CreateCustomFieldAsync(name, type);
                if (ok) created++;
            }
        }
        await LoadCfNamesAsync();
        _setupMessage = created > 0 ? $"{created} Felder angelegt." : "Alle Felder bereits vorhanden.";
        _creatingMissingFields = false;
    }

    private async Task LoadCfNamesAsync()
    {
        // 1. Zuerst aus Paperless-API laden (direkt, unabhängig von lokaler Einstellungsliste)
        try
        {
            var fields = await Api.GetCustomFieldsAsync();
            if (fields?.Count > 0)
            {
                _cfNames = fields.Select(f => f.Name).ToList();
                return;
            }
        }
        catch { }
        // 2. Fallback: lokale Einstellungsliste
        _cfNames = (_settings.EnabledCustomFieldNames ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }
    private void LoadCfNames() => _ = LoadCfNamesAsync();

